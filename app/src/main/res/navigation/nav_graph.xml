<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.siapsen.ui.home.HomeFragment"
        android:label="Beranda"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_absen"
            app:destination="@id/absenFragment" />
        <action
            android:id="@+id/action_home_to_izinCuti"
            app:destination="@id/izinCutiFragment" />
    </fragment>

    <fragment
        android:id="@+id/absenFragment"
        android:name="com.example.siapsen.ui.absen.AbsenFragment"
        android:label="Absen"
        tools:layout="@layout/fragment_absen">
        <argument
            android:name="attendanceType"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/izinCutiFragment"
        android:name="com.example.siapsen.ui.izin.IzinCutiFragment"
        android:label="Izin / Cuti"
        tools:layout="@layout/fragment_izin_cuti">
        <argument
            android:name="leaveType"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/riwayatFragment"
        android:name="com.example.siapsen.ui.riwayat.RiwayatFragment"
        android:label="Riwayat"
        tools:layout="@layout/fragment_riwayat" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.siapsen.ui.profile.ProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profile_to_edit"
            app:destination="@id/editProfileFragment"/>
        <action
            android:id="@+id/action_profile_to_changePassword"
            app:destination="@id/changePasswordFragment"/>

    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.siapsen.ui.editprofile.EditProfileFragment"
        android:label="Edit Profil"
        tools:layout="@layout/fragment_edit_profile"/>

    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.example.siapsen.ui.changepassword.ChangePasswordFragment"
        android:label="Ganti Password"
        tools:layout="@layout/fragment_change_password"/>
    <fragment
        android:id="@+id/approvalFragment"
        android:name="com.example.siapsen.ui.approval.ApprovalFragment"
        android:label="Approval"
        tools:layout="@layout/fragment_approval"/>
    <fragment
        android:id="@+id/hrFragment"
        android:name="com.example.siapsen.ui.hr.HrFragment"
        android:label="Kelola Presensi"
        tools:layout="@layout/fragment_hr"/>

</navigation>
